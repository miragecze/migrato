<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Migrato.App.App"
             RequestedThemeVariant="Light">

  <Application.Resources>
    <!-- Značkový gradient — stejný jako ikona aplikace. -->
    <LinearGradientBrush x:Key="BrandGradient" StartPoint="0%,0%" EndPoint="100%,100%">
      <GradientStop Color="#2563EB" Offset="0" />
      <GradientStop Color="#7C3AED" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="BrandGradientHover" StartPoint="0%,0%" EndPoint="100%,100%">
      <GradientStop Color="#1D4ED8" Offset="0" />
      <GradientStop Color="#6D28D9" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="WindowGradient" StartPoint="0%,0%" EndPoint="100%,100%">
      <GradientStop Color="#EEF3FF" Offset="0" />
      <GradientStop Color="#F6F3FF" Offset="0.55" />
      <GradientStop Color="#FBF2FB" Offset="1" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="CardBrush" Color="White" />
    <SolidColorBrush x:Key="CardBorderBrush" Color="#E3E7F4" />
    <SolidColorBrush x:Key="InkBrush" Color="#1E293B" />

    <!-- Šipka z ikony aplikace — vodoznak, logo i drobné akcenty. -->
    <StreamGeometry x:Key="ArrowGeometry">M 10,40 L 52,40 L 52,26 L 86,50 L 52,74 L 52,60 L 10,60 Z</StreamGeometry>
  </Application.Resources>

  <Application.Styles>
    <FluentTheme />

    <!-- Hlavní akční tlačítka ve značkovém gradientu. -->
    <Style Selector="Button.accent">
      <Setter Property="Background" Value="{StaticResource BrandGradient}" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="Button.accent:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{StaticResource BrandGradientHover}" />
      <Setter Property="Foreground" Value="White" />
    </Style>
    <Style Selector="Button.accent:pressed /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{StaticResource BrandGradientHover}" />
      <Setter Property="Foreground" Value="White" />
    </Style>

    <!-- Velké karty voleb na úvodní obrazovce. -->
    <Style Selector="Button.role">
      <Setter Property="Background" Value="{StaticResource CardBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="12" />
    </Style>
    <Style Selector="Button.role:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="#F5F8FF" />
    </Style>

    <!-- Bílá karta kolem seznamů. -->
    <Style Selector="Border.card">
      <Setter Property="Background" Value="{StaticResource CardBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="12" />
      <Setter Property="Padding" Value="10" />
    </Style>

    <Style Selector="ProgressBar">
      <Setter Property="Foreground" Value="{StaticResource BrandGradient}" />
      <Setter Property="Background" Value="#E4E8F5" />
    </Style>
  </Application.Styles>
</Application>
