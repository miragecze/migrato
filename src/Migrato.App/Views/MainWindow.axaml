<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Migrato.App.ViewModels"
        xmlns:views="using:Migrato.App.Views"
        x:Class="Migrato.App.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="Migrato"
        Icon="/Assets/migrato.ico"
        Width="920" Height="680" MinWidth="720" MinHeight="560"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowGradient}">

  <Window.DataTemplates>
    <DataTemplate DataType="{x:Type vm:HomeViewModel}">
      <views:HomeView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:ReceiveViewModel}">
      <views:ReceiveView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:SendViewModel}">
      <views:SendView />
    </DataTemplate>
  </Window.DataTemplates>

  <Grid>
    <!-- Vodoznak značkové šipky za obsahem celého okna. -->
    <Viewbox Width="620" HorizontalAlignment="Right" VerticalAlignment="Center"
             Margin="0,0,-150,0" Opacity="0.06" IsHitTestVisible="False">
      <Path Data="{StaticResource ArrowGeometry}" Fill="{StaticResource BrandGradient}" />
    </Viewbox>
    <ContentControl Content="{Binding CurrentPage}" />
  </Grid>
</Window>
