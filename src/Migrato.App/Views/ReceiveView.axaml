<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Migrato.App.ViewModels"
             x:Class="Migrato.App.Views.ReceiveView"
             x:DataType="vm:ReceiveViewModel">

  <Grid Margin="32" RowDefinitions="*,Auto">
    <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center"
                Spacing="14" MaxWidth="640">

      <!-- Čekání na spárování / waiting for pairing -->
      <StackPanel Spacing="14" IsVisible="{Binding IsWaiting}">
        <TextBlock Text="{Binding L.RcvTitle}" FontSize="24" FontWeight="SemiBold"
                   HorizontalAlignment="Center" />
        <TextBlock Text="{Binding MachineInfo}" Opacity="0.7" HorizontalAlignment="Center" />
        <Border Background="{DynamicResource SystemControlBackgroundListLowBrush}"
                CornerRadius="14" Padding="36,20" HorizontalAlignment="Center" Margin="0,10">
          <StackPanel Spacing="6">
            <TextBlock Text="{Binding L.RcvPinLabel}" FontSize="13" Opacity="0.7"
                       HorizontalAlignment="Center" />
            <TextBlock Text="{Binding Pin}" FontSize="56" FontWeight="Bold" LetterSpacing="8"
                       HorizontalAlignment="Center" />
          </StackPanel>
        </Border>
        <TextBlock Text="{Binding L.RcvInstruction}"
                   TextWrapping="Wrap" TextAlignment="Center" Opacity="0.75" />
        <TextBlock Text="{Binding AddressInfo}" FontSize="13" Opacity="0.6"
                   HorizontalAlignment="Center"
                   IsVisible="{Binding AddressInfo, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
        <TextBlock Text="{Binding L.KeepLidOpen}" FontSize="12" Opacity="0.55"
                   TextWrapping="Wrap" TextAlignment="Center" />
      </StackPanel>

      <!-- Průběh přenosu / transfer progress -->
      <StackPanel Spacing="12" IsVisible="{Binding IsTransferring}">
        <TextBlock Text="{Binding L.RcvReceiving}" FontSize="24" FontWeight="SemiBold"
                   HorizontalAlignment="Center" />
        <ProgressBar Value="{Binding ProgressPercent}" Maximum="100" Height="14" CornerRadius="7" />
        <TextBlock Text="{Binding ProgressText}" HorizontalAlignment="Center" />
        <TextBlock Text="{Binding CurrentFile}" Opacity="0.6" FontSize="12" HorizontalAlignment="Center"
                   TextTrimming="CharacterEllipsis" MaxWidth="560" />
      </StackPanel>

      <!-- Hotovo / done -->
      <StackPanel Spacing="12" IsVisible="{Binding IsDone}">
        <TextBlock Text="{Binding L.RcvDone}" FontSize="28" FontWeight="SemiBold"
                   HorizontalAlignment="Center" />
        <TextBlock Text="{Binding SummaryText}" TextWrapping="Wrap" TextAlignment="Center" />
        <ItemsControl ItemsSource="{Binding PostResultLines}" HorizontalAlignment="Center">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="x:String">
              <TextBlock Text="{Binding}" FontSize="13" Opacity="0.8" Margin="0,2" TextWrapping="Wrap" />
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
        <Button Content="{Binding L.SaveReport}" Command="{Binding SaveReportCommand}"
                HorizontalAlignment="Center" Padding="16,6" />
        <TextBlock Text="{Binding ReportInfo}" FontSize="12" Opacity="0.65" TextWrapping="Wrap"
                   TextAlignment="Center"
                   IsVisible="{Binding ReportInfo, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
        <HyperlinkButton Content="{Binding L.ReportIssue}" NavigateUri="{x:Static vm:UI.IssuesUri}"
                         FontSize="12" HorizontalAlignment="Center" />
      </StackPanel>

      <TextBlock Text="{Binding Status}" Opacity="0.65" FontSize="13" HorizontalAlignment="Center"
                 IsVisible="{Binding !IsDone}" />
      <TextBlock Text="{Binding ErrorText}" Foreground="OrangeRed" TextWrapping="Wrap"
                 TextAlignment="Center" IsVisible="{Binding ErrorText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
    </StackPanel>

    <Button Grid.Row="1" Command="{Binding CancelCommand}" HorizontalAlignment="Center" Padding="24,8"
            Content="{Binding CancelLabel}" />
  </Grid>
</UserControl>
