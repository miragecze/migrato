<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Migrato.App.ViewModels"
             x:Class="Migrato.App.Views.SendView"
             x:DataType="vm:SendViewModel">

  <Grid Margin="32" RowDefinitions="Auto,*,Auto">

    <TextBlock Grid.Row="0" Text="{Binding ErrorText}" Foreground="OrangeRed" TextWrapping="Wrap"
               Margin="0,0,0,10"
               IsVisible="{Binding ErrorText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

    <!-- Krok 1: výběr zařízení / device selection -->
    <Grid Grid.Row="1" RowDefinitions="Auto,Auto,*,Auto,Auto" IsVisible="{Binding StepDevices}">
      <TextBlock Grid.Row="0" Text="{Binding L.SndPickTitle}" FontSize="24" FontWeight="SemiBold" />
      <TextBlock Grid.Row="1" Margin="0,6,0,14" Opacity="0.7" TextWrapping="Wrap"
                 Text="{Binding L.SndPickHint}" />
      <ListBox Grid.Row="2" ItemsSource="{Binding Devices}" SelectedItem="{Binding SelectedDevice}"
               Background="{StaticResource CardBrush}" CornerRadius="12" Padding="6"
               BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1">
        <ListBox.ItemTemplate>
          <DataTemplate x:DataType="vm:DeviceVm">
            <StackPanel Orientation="Horizontal" Spacing="12" Margin="4">
              <TextBlock Text="💻" FontSize="22" VerticalAlignment="Center" />
              <StackPanel>
                <TextBlock Text="{Binding Machine}" FontWeight="SemiBold" FontSize="15" />
                <TextBlock Text="{Binding Detail}" FontSize="12" Opacity="0.6" />
              </StackPanel>
            </StackPanel>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
      <StackPanel Grid.Row="3" Spacing="6" Margin="0,12,0,0">
        <TextBlock Text="{Binding L.SndManualHint}" FontSize="12" Opacity="0.6" TextWrapping="Wrap" />
        <Grid ColumnDefinitions="*,Auto">
          <TextBox Grid.Column="0" Text="{Binding ManualAddress}" Watermark="192.168.1.5:51234"
                   Margin="0,0,8,0" />
          <Button Grid.Column="1" Content="{Binding L.SndManualButton}"
                  Command="{Binding ManualConnectCommand}" Padding="14,6" />
        </Grid>
      </StackPanel>
      <StackPanel Grid.Row="4" Orientation="Horizontal" Spacing="10" Margin="0,14,0,0"
                  HorizontalAlignment="Right">
        <Button Content="{Binding L.Back}" Command="{Binding BackCommand}" Padding="20,8" />
        <Button Content="{Binding L.Continue}" Command="{Binding ChooseDeviceCommand}" Padding="20,8"
                Classes="accent"
                IsEnabled="{Binding SelectedDevice, Converter={x:Static ObjectConverters.IsNotNull}}" />
      </StackPanel>
    </Grid>

    <!-- Krok 2: PIN -->
    <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16"
                IsVisible="{Binding StepPin}">
      <TextBlock Text="{Binding L.SndPinTitle}" FontSize="24" FontWeight="SemiBold"
                 HorizontalAlignment="Center" />
      <TextBlock Text="{Binding L.SndPinHint}" Opacity="0.7" HorizontalAlignment="Center" />
      <TextBox Text="{Binding PinText}" MaxLength="6" Width="220" FontSize="34"
               HorizontalContentAlignment="Center" HorizontalAlignment="Center" Watermark="000000" />
      <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
        <Button Content="{Binding L.Back}" Command="{Binding BackCommand}" Padding="20,8" />
        <Button Content="{Binding L.Continue}" Command="{Binding ConnectCommand}" Padding="20,8"
                Classes="accent" />
      </StackPanel>
    </StackPanel>

    <!-- Krok 3: skenování / scanning -->
    <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16"
                IsVisible="{Binding StepScan}">
      <TextBlock Text="{Binding L.SndScanTitle}" FontSize="22" FontWeight="SemiBold"
                 HorizontalAlignment="Center" />
      <ProgressBar IsIndeterminate="True" Width="360" Height="10" />
      <TextBlock Text="{Binding ScanStatus}" Opacity="0.7" HorizontalAlignment="Center" />
    </StackPanel>

    <!-- Krok 4: výběr obsahu / content selection -->
    <Grid Grid.Row="1" RowDefinitions="Auto,*,Auto" IsVisible="{Binding StepSelect}">
      <TextBlock Grid.Row="0" Text="{Binding L.SndSelectTitle}" FontSize="24" FontWeight="SemiBold"
                 Margin="0,0,0,12" />
      <Border Grid.Row="1" Classes="card">
      <ScrollViewer>
        <ItemsControl ItemsSource="{Binding Groups}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:GroupVm">
              <Border BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                      BorderThickness="0,0,0,1" Padding="4,10">
                <Grid ColumnDefinitions="Auto,Auto,*,Auto">
                  <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}" VerticalAlignment="Center" />
                  <TextBlock Grid.Column="1" Text="{Binding Icon}" FontSize="22" Margin="6,0,12,0"
                             VerticalAlignment="Center" />
                  <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="2">
                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="15" />
                    <TextBlock Text="{Binding Description}" FontSize="12" Opacity="0.65"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding WarningText}" FontSize="12" Foreground="Orange"
                               TextWrapping="Wrap" IsVisible="{Binding HasWarning}" />
                    <Expander Header="{Binding PackagesHeader}" IsVisible="{Binding HasPackages}"
                              FontSize="12" Margin="0,6,0,0">
                      <ScrollViewer MaxHeight="240">
                        <ItemsControl ItemsSource="{Binding Packages}">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:PackageVm">
                              <CheckBox IsChecked="{Binding IsSelected}" Content="{Binding Id}"
                                        FontSize="12" Padding="6,2" MinHeight="26" />
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                      </ScrollViewer>
                    </Expander>
                    <Expander Header="{Binding SubItemsHeader}" IsVisible="{Binding HasSubItems}"
                              FontSize="12" Margin="0,6,0,0">
                      <ScrollViewer MaxHeight="240">
                        <ItemsControl ItemsSource="{Binding SubItems}">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:SubItemVm">
                              <CheckBox IsChecked="{Binding IsSelected}" Content="{Binding Display}"
                                        FontSize="12" Padding="6,2" MinHeight="26" />
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                      </ScrollViewer>
                    </Expander>
                  </StackPanel>
                  <TextBlock Grid.Column="3" Text="{Binding SizeText}" FontSize="13" Opacity="0.7"
                             VerticalAlignment="Center" Margin="12,0,0,0" />
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>
      </Border>
      <Grid Grid.Row="2" ColumnDefinitions="Auto,*,Auto" Margin="0,14,0,0">
        <StackPanel Grid.Column="0" Margin="0,0,14,0" Spacing="2">
          <Button Content="{Binding L.AddCustomFolder}"
                  Command="{Binding AddCustomFolderCommand}" Padding="14,8" />
          <TextBlock Text="{Binding L.AddCustomFolderHint}" FontSize="11" Opacity="0.55"
                     TextWrapping="Wrap" MaxWidth="240" />
        </StackPanel>
        <TextBlock Grid.Column="1" Text="{Binding SelectedTotalText}" VerticalAlignment="Center"
                   FontWeight="SemiBold" />
        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10">
          <Button Content="{Binding L.Back}" Command="{Binding BackCommand}" Padding="20,8" />
          <Button Content="{Binding L.SndStart}" Command="{Binding TransferCommand}" Padding="20,8"
                  Classes="accent" />
        </StackPanel>
      </Grid>
    </Grid>

    <!-- Krok 5: přenos / transfer -->
    <StackPanel Grid.Row="1" VerticalAlignment="Center" Spacing="14" MaxWidth="640"
                IsVisible="{Binding StepTransfer}">
      <TextBlock Text="{Binding L.SndTransferring}" FontSize="24" FontWeight="SemiBold"
                 HorizontalAlignment="Center" />
      <ProgressBar Value="{Binding ProgressPercent}" Maximum="100" Height="14" CornerRadius="7" />
      <TextBlock Text="{Binding ProgressText}" HorizontalAlignment="Center" />
      <TextBlock Text="{Binding CurrentFile}" Opacity="0.6" FontSize="12" HorizontalAlignment="Center"
                 TextTrimming="CharacterEllipsis" MaxWidth="560" />
      <TextBlock Text="{Binding TransferStatus}" Opacity="0.7" FontSize="13"
                 HorizontalAlignment="Center" />
      <TextBlock Text="{Binding L.KeepLidOpen}" FontSize="12" Opacity="0.55"
                 TextWrapping="Wrap" TextAlignment="Center" />
      <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
        <Button Content="{Binding PauseLabel}" Command="{Binding PauseResumeCommand}" Padding="20,8" />
        <Button Content="{Binding L.Cancel}" Command="{Binding CancelTransferCommand}" Padding="20,8" />
      </StackPanel>
    </StackPanel>

    <!-- Krok 6: hotovo / done -->
    <StackPanel Grid.Row="1" VerticalAlignment="Center" Spacing="14" MaxWidth="640"
                IsVisible="{Binding StepDone}">
      <TextBlock Text="{Binding L.SndDoneTitle}" FontSize="28" FontWeight="SemiBold"
                 HorizontalAlignment="Center" />
      <TextBlock Text="{Binding SummaryText}" TextWrapping="Wrap" TextAlignment="Center" />
      <ItemsControl ItemsSource="{Binding PostResultLines}" HorizontalAlignment="Center">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="x:String">
            <TextBlock Text="{Binding}" FontSize="13" Opacity="0.8" Margin="0,2" TextWrapping="Wrap" />
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
      <Button Content="{Binding L.SaveReport}" Command="{Binding SaveReportCommand}"
              HorizontalAlignment="Center" Padding="16,6" />
      <TextBlock Text="{Binding ReportInfo}" FontSize="12" Opacity="0.65" TextWrapping="Wrap"
                 TextAlignment="Center"
                 IsVisible="{Binding ReportInfo, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
      <HyperlinkButton Content="{Binding L.ReportIssue}" NavigateUri="{x:Static vm:UI.IssuesUri}"
                       FontSize="12" HorizontalAlignment="Center" />
      <Button Content="{Binding L.SndHome}" Command="{Binding FinishCommand}"
              HorizontalAlignment="Center" Padding="24,8" Classes="accent" />
    </StackPanel>
  </Grid>
</UserControl>
